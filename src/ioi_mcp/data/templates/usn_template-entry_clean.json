[
  {
    "@id": "kb:usn-entry--{ENTRY_UUID}",
    "@type": "observable:File",
    "core:hasFacet": [
      {
        "@id": "kb:usn-entry-file-facet--{ENTRY_UUID}",
        "@type": "observable:FileFacet",
        "observable:fileName": "{FILE_NAME}",
        "observable:extension": "{FILE_EXTENSION}",
        "observable:filePath": "{FILE_PATH}",
        "observable:modifiedTime": {
          "@type": "xsd:dateTime",
          "@value": "{UPDATE_TIMESTAMP}"
        }
      },
      {
        "@id": "kb:usn-entry-custom-facet--{ENTRY_UUID}",
        "@type": [
          "ioi-ext:UsnFacet",
          "core:Facet"
        ],
        "ioi-ext:entryNumber": {
          "@type": "xsd:integer",
          "@value": "{ENTRY_NUMBER}"
        },
        "ioi-ext:sequenceNumber": {
          "@type": "xsd:integer",
          "@value": "{SEQUENCE_NUMBER}"
        },
        "ioi-ext:parentEntryNumber": {
          "@type": "xsd:integer",
          "@value": "{PARENT_ENTRY_NUMBER}"
        },
        "ioi-ext:parentSequenceNumber": {
          "@type": "xsd:integer",
          "@value": "{PARENT_SEQUENCE_NUMBER}"
        },
        "ioi-ext:parentPath": "{PARENT_PATH}",
        "ioi-ext:updateSequenceNumber": {
          "@type": "xsd:integer",
          "@value": "{UPDATE_SEQUENCE_NUMBER}"
        },
        "ioi-ext:updateTimestamp": {
          "@type": "xsd:dateTime",
          "@value": "{UPDATE_TIMESTAMP}"
        },
        "ioi-ext:updateReasons": "{UPDATE_REASONS}",
        "ioi-ext:fileAttributes": "{FILE_ATTRIBUTES}",
        "ioi-ext:offsetToData": {
          "@type": "xsd:integer",
          "@value": "{OFFSET_TO_DATA}"
        },
        "ioi-ext:sourceFile": "{SOURCE_FILE}"
      }
    ]
  }
]
